#!/usr/bin/env node
/**
 * Fake `claude` binary for Task 9 Step 2 (embedded-session feed E2E without a live CLI).
 * Drop this directory at the front of PATH so ClaudeAdapter's spawn('claude', …) finds us.
 *
 * Protocol: NDJSON on stdin/stdout, matching the stream-json shapes pinned in
 * packages/the-forge/tests/server/session/fixtures/claude-ndjson.ts.
 *
 * Scenarios (FORGE_FAKE_CLAUDE_SCENARIO):
 *   default (or unset) — init → on user turn: text + Edit tool_use + tool_result + success
 *   rate-limit         — init → on user turn: in-band rate-limit result (is_error:true)
 *   chat                — init → on user turn: 3 stream_event text deltas + final assistant text
 *                         + Edit tool_use (old_string/new_string) + tool_result + success
 *                         (milestone B / Task 7 E2E — shapes copied from the spike fixtures in
 *                         packages/the-forge/tests/server/session/fixtures/claude-chat-ndjson.ts)
 *
 * Stays alive until SIGTERM/SIGINT (SessionManager.stop / process exit).
 */
'use strict'

const { randomUUID } = require('node:crypto')
const readline = require('node:readline')

const SESSION_ID = process.env.FORGE_FAKE_SESSION_ID || 'fake-session-e2e-0001'
const SCENARIO = process.env.FORGE_FAKE_CLAUDE_SCENARIO || 'default'

function emit(obj) {
  process.stdout.write(JSON.stringify(obj) + '\n')
}

function emitInit() {
  emit({
    type: 'system',
    subtype: 'init',
    cwd: process.cwd(),
    session_id: SESSION_ID,
    tools: ['Bash', 'Edit', 'Read', 'Write', 'Grep', 'Glob'],
    mcp_servers: [{ name: 'the-forge', status: 'connected' }],
    model: 'fake-claude-e2e',
    permissionMode: 'default',
    apiKeySource: 'none',
  })
}

function emitDefaultTurn() {
  const toolId = 'toolu_fake_edit_1'
  emit({
    type: 'assistant',
    session_id: SESSION_ID,
    message: {
      role: 'assistant',
      content: [{ type: 'text', text: 'Applying the queued design edits.' }],
    },
  })
  emit({
    type: 'assistant',
    session_id: SESSION_ID,
    message: {
      role: 'assistant',
      content: [
        {
          type: 'tool_use',
          id: toolId,
          name: 'Edit',
          input: { file_path: 'src/App.tsx' },
        },
      ],
    },
  })
  // Brief pause so the feed can render the in-flight tool row before finish.
  setTimeout(() => {
    emit({
      type: 'user',
      session_id: SESSION_ID,
      message: {
        role: 'user',
        content: [{ type: 'tool_result', tool_use_id: toolId, content: 'ok' }],
      },
    })
    emit({
      type: 'result',
      subtype: 'success',
      is_error: false,
      num_turns: 1,
      result: 'done',
      session_id: SESSION_ID,
      total_cost_usd: 0.001,
    })
  }, 50)
}

// Milestone B / Task 7: chat scenario for the /session/say E2E section in
// scripts/e2e-embedded-feed.sh. Envelope shapes (stream_event delta, the tool_use/tool_result/
// result sequence) are copied from the spike fixtures — see claude-chat-ndjson.ts §Step 1.
function emitChatTurn() {
  const toolId = 'toolu_fake_chat_edit_1'
  const deltaChunks = ['Sure, I can ', 'help with ', 'that.']
  for (const text of deltaChunks) {
    emit({
      type: 'stream_event',
      event: { type: 'content_block_delta', index: 1, delta: { type: 'text_delta', text } },
      session_id: SESSION_ID,
      parent_tool_use_id: null,
      uuid: randomUUID(),
    })
  }
  emit({
    type: 'assistant',
    session_id: SESSION_ID,
    message: {
      role: 'assistant',
      content: [{ type: 'text', text: deltaChunks.join('') }],
    },
  })
  emit({
    type: 'assistant',
    session_id: SESSION_ID,
    message: {
      role: 'assistant',
      content: [
        {
          type: 'tool_use',
          id: toolId,
          name: 'Edit',
          input: {
            file_path: 'src/App.tsx',
            old_string: 'const greeting = "hi"',
            new_string: 'const greeting = "hello from e2e"',
          },
        },
      ],
    },
  })
  // Brief pause so the feed can render the in-flight tool row before finish (same as default).
  setTimeout(() => {
    emit({
      type: 'user',
      session_id: SESSION_ID,
      message: {
        role: 'user',
        content: [{ type: 'tool_result', tool_use_id: toolId, content: 'ok' }],
      },
    })
    emit({
      type: 'result',
      subtype: 'success',
      is_error: false,
      num_turns: 1,
      result: 'done',
      session_id: SESSION_ID,
      total_cost_usd: 0.001,
    })
  }, 50)
}

function emitRateLimitTurn() {
  emit({
    type: 'assistant',
    session_id: SESSION_ID,
    message: {
      role: 'assistant',
      content: [
        {
          type: 'text',
          text: "You've hit your weekly limit · resets Jul 12 at 12am (America/New_York)",
        },
      ],
    },
  })
  emit({
    type: 'result',
    subtype: 'success',
    is_error: true,
    api_error_status: 429,
    num_turns: 1,
    result: "You've hit your weekly limit · resets Jul 12 at 12am (America/New_York)",
    session_id: SESSION_ID,
    total_cost_usd: 0,
  })
}

function handleUserTurn() {
  if (SCENARIO === 'rate-limit') emitRateLimitTurn()
  else if (SCENARIO === 'chat') emitChatTurn()
  else emitDefaultTurn()
}

// LAZY BOOT — matches the real CLI (verified live, 2.1.201): with stdin open but silent,
// `claude -p --input-format stream-json` emits NOTHING — no hooks, no init — until the
// first input line arrives. Emitting init eagerly here masked a real deadlock (manager
// waited for init, CLI waited for input); init now fires only on first message, plus a
// hook_started line first, mirroring the real boot chatter (mapped to `activity`).
let booted = false

const rl = readline.createInterface({ input: process.stdin, crlfDelay: Infinity })
rl.on('line', (line) => {
  const trimmed = line.trim()
  if (!trimmed) return
  let msg
  try {
    msg = JSON.parse(trimmed)
  } catch {
    return
  }
  if (!booted) {
    booted = true
    emit({ type: 'system', subtype: 'hook_started', hook_id: 'fake-hook-1', hook_name: 'SessionStart:startup' })
    emitInit()
  }
  if (msg && msg.type === 'user') {
    handleUserTurn()
    return
  }
  // control_request acks — every scenario, not just chat, so setConfig()'s live stdin writes
  // (setModel/setPermissionMode, called regardless of which scenario is running) always get a
  // reply. Shapes copied from claude-chat-ndjson.ts §Step 2 (live-probed, CLI 2.1.201).
  if (msg && msg.type === 'control_request' && msg.request) {
    const requestId = msg.request_id || randomUUID()
    const subtype = msg.request.subtype
    if (subtype === 'interrupt') {
      // Interrupt is acknowledged by staying alive; the manager doesn't require a reply.
      emit({ type: 'control_response', response: { subtype: 'success', request_id: requestId } })
    } else if (subtype === 'set_model') {
      // No echo of the applied model — confirmation comes from a later assistant/result event.
      emit({ type: 'control_response', response: { subtype: 'success', request_id: requestId } })
    } else if (subtype === 'set_permission_mode') {
      // Unlike set_model, this ack DOES echo the applied mode.
      emit({
        type: 'control_response',
        response: { subtype: 'success', request_id: requestId, response: { mode: msg.request.mode } },
      })
    }
  }
})

function shutdown() {
  try {
    rl.close()
  } catch {
    /* ignore */
  }
  process.exit(0)
}
process.on('SIGTERM', shutdown)
process.on('SIGINT', shutdown)

// Keep the event loop alive even if stdin closes unexpectedly.
setInterval(() => {}, 60_000)
