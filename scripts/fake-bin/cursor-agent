// PROMPT_RESPONSE_END_TURN === PROMPT_RESPONSE_END_TURN_AFTER_REJECT in the fixtures — a
// rejected turn still resolves end_turn (Scenario 6); one constant serves both.
const PROMPT_RESPONSE_END_TURN = "{\"jsonrpc\":\"2.0\",\"id\":3,\"result\":{\"stopReason\":\"end_turn\"}}"

const PROMPT_RESPONSE_CANCELLED = "{\"jsonrpc\":\"2.0\",\"id\":3,\"result\":{\"stopReason\":\"cancelled\"}}"

// session/load with an unknown sessionId (this fake persists nothing across spawns, so every
// resume id is stale by definition) → the recorded -32602 stale-session error. The manager's
// stale-resume branch then clears the slot and retries fresh via session/new — so a leftover
// session.json can never wedge the E2E.
const LOAD_STALE_ERROR = "{\"jsonrpc\":\"2.0\",\"id\":3,\"error\":{\"code\":-32602,\"message\":\"Invalid params\",\"data\":{\"message\":\"Session \\\"00000000-0000-0000-0000-000000000000\\\" not found\"}}}"

// ---------------------------------------------------------------------------------------

function writeLine(json) {
  process.stdout.write(json + '\n')
}

/** Emit a canned line, echoing the request's JSON-RPC id and/or patching params.sessionId
 * to the live session — the ONLY permitted adjustments to the byte-copied fixtures. */
function emitCanned(canned, patch) {
  const obj = JSON.parse(canned)
  if (patch && patch.id !== undefined) obj.id = patch.id
  if (patch && patch.sessionId !== undefined && obj.params && typeof obj.params === 'object') {
    obj.params.sessionId = patch.sessionId
  }
  writeLine(JSON.stringify(obj))
}

function logReceipt(obj) {
  if (!RECEIPT_LOG) return
  try {
    require('node:fs').appendFileSync(RECEIPT_LOG, JSON.stringify(obj) + '\n')
  } catch {
    // Best-effort — a failed receipt write must never break the protocol.
  }
}

// Live state: the sessionId handed out by session/new, the in-flight prompt's request id
// (so the prompt response can echo it), and whether our server→client permission request
// (id 0 — the recorded server reuses 0 per turn) is awaiting the client's answer.
let sessionId = ''
let pendingPromptId = null
let permissionOutstanding = false

function handlePrompt(msg) {
  pendingPromptId = msg.id
  logReceipt({ received: 'session/prompt' })
  emitCanned(AGENT_THOUGHT_CHUNK, { sessionId })
  emitCanned(AGENT_MESSAGE_CHUNK, { sessionId })
  emitCanned(TOOL_CALL_STARTED_EXECUTE, { sessionId })
  // Brief pause so the feed can render the in-flight tool row before the permission
  // request parks the turn (same 50ms convention as the fake claude's tool_result delay).
  permissionOutstanding = true
  setTimeout(() => {
    if (!permissionOutstanding) return // cancelled in the window
    emitCanned(PERMISSION_REQUEST_EXECUTE, { sessionId })
  }, 50)
}

function handlePermissionAnswer(msg) {
  permissionOutstanding = false
  const outcome = msg.result && msg.result.outcome ? msg.result.outcome : {}
  logReceipt({ received: 'permission_response', outcome: outcome.outcome, optionId: outcome.optionId })
  emitCanned(TOOL_CALL_UPDATE_AFTER_REJECT, { sessionId })
  if (pendingPromptId !== null) {
    emitCanned(PROMPT_RESPONSE_END_TURN, { id: pendingPromptId })
    pendingPromptId = null
  }
}

const rl = readline.createInterface({ input: process.stdin, crlfDelay: Infinity })
rl.on('line', (line) => {
  const trimmed = line.trim()
  if (!trimmed) return
  let msg
  try {
    msg = JSON.parse(trimmed)
  } catch {
    return
  }
  if (!msg || typeof msg !== 'object') return

  if (msg.method === 'initialize') {
    logReceipt({ received: 'initialize' })
    emitCanned(INIT_RESPONSE, { id: msg.id })
    return
  }
  if (msg.method === 'session/new') {
    const mcpServers = Array.isArray(msg.params && msg.params.mcpServers)
      ? msg.params.mcpServers.map((s) => s && s.name)
      : []
    logReceipt({ received: 'session/new', mcpServers })
    const resp = JSON.parse(SESSION_NEW_RESPONSE)
    resp.id = msg.id
    sessionId = resp.result.sessionId
    writeLine(JSON.stringify(resp))
    return
  }
  if (msg.method === 'session/load') {
    // Never resumable (see LOAD_STALE_ERROR's why-comment).
    logReceipt({ received: 'session/load' })
    emitCanned(LOAD_STALE_ERROR, { id: msg.id })
    return
  }
  if (msg.method === 'session/prompt') {
    handlePrompt(msg)
    return
  }
  if (msg.method === 'session/cancel') {
    logReceipt({ received: 'session/cancel' })
    permissionOutstanding = false
    if (pendingPromptId !== null) {
      emitCanned(PROMPT_RESPONSE_CANCELLED, { id: pendingPromptId })
      pendingPromptId = null
    }
    return
  }
  // No method → a response to OUR server→client request. The only one we send is the
  // permission request (id 0).
  if (msg.method === undefined && msg.id === 0 && permissionOutstanding) {
    handlePermissionAnswer(msg)
  }
})

function shutdown() {
  try {
    rl.close()
  } catch {
    /* ignore */
  }
  process.exit(0)
}
process.on('SIGTERM', shutdown)
process.on('SIGINT', shutdown)

// Keep the event loop alive even if stdin closes unexpectedly.
setInterval(() => {}, 60_000)
