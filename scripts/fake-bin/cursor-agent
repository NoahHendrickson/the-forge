#!/usr/bin/env node
/**
 * Fake `cursor-agent` binary for the C1 Task 6 harness-switch E2E (embedded-session feed
 * without a live Cursor CLI). Drop this directory at the front of PATH so CursorAdapter's
 * spawn('cursor-agent', ['acp'], …) finds us — same PATH-fronting contract as the fake
 * `claude` next door.
 *
 * Protocol: ACP — JSON-RPC 2.0, newline-delimited, over stdio (protocol on stdout, nothing
 * on stderr — the live CLI's stderr was empty for every recorded scenario). Every canned
 * line below is byte-copied from the recorded ground truth in
 * packages/the-forge/tests/server/session/fixtures/cursor-acp-jsonrpc.ts (Task 1 spike,
 * CLI 2026.07.09); the only runtime adjustments are the JSON-RPC `id` (must echo the
 * request's id) and `params.sessionId` on notifications (patched to the live session).
 *
 * Turn script (one session/prompt): agent_thought_chunk → agent_message_chunk ("ping") →
 * tool_call (kind:execute, `touch /tmp/forge-spike-probe`) → session/request_permission
 * (server→client REQUEST, id 0) → wait for the client's answer → tool_call_update
 * (status:completed — the Scenario 6 gotcha: a REJECTED tool still reports completed) →
 * prompt response {stopReason:"end_turn"} (a rejected turn still resolves end_turn).
 *
 * Receipt log (FORGE_FAKE_CURSOR_LOG — mirrors FORGE_FAKE_CLAUDE_LOG): the adapter answers
 * permission requests on our stdin, which nothing server-side records, so the E2E's "the
 * reject-once answer actually landed in the CLI" assertion needs a record the FAKE owns.
 * One JSON line per notable inbound message. Sidecar only — never touches the protocol.
 *
 * Stays alive until SIGTERM/SIGINT (SessionManager.stop / harness switch / process exit).
 */
'use strict'

const readline = require('node:readline')

const RECEIPT_LOG = process.env.FORGE_FAKE_CURSOR_LOG || ''

