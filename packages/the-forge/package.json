{
  "name": "the-forge",
  "version": "0.0.1",
  "type": "module",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
    "./vite": { "types": "./dist/vite.d.ts", "default": "./dist/vite.js" },
    "./next": { "types": "./dist/next.d.ts", "default": "./dist/next.js" },
    "./design-mode": { "types": "./dist/design-mode.d.ts", "default": "./dist/design-mode.js" }
  },
  "files": ["dist"],
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\" && tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@babel/parser": "^7.26.0",
    "magic-string": "^0.30.0"
  },
  "peerDependencies": {
    "vite": ">=5",
    "next": ">=15",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "vite": { "optional": true },
    "next": { "optional": true },
    "react": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "jsdom": "^25.0.0",
    "react": "^18.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
